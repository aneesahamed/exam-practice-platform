# Local development environment variables
# Copy to .env.local and fill in values from your dev AWS deployment
# Never commit .env.local — it is gitignored

# API Gateway URL (from SAM stack output)
VITE_API_BASE_URL=https://your-api-id.execute-api.eu-west-1.amazonaws.com/dev

# Cognito (from Terraform output)
VITE_COGNITO_USER_POOL_ID=eu-west-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_AWS_REGION=eu-west-1
